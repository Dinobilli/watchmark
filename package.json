{
  "name": "watchmark",
  "version": "0.1.1",
  "description": "Open-source website change monitor with meaningful summaries for Korean public notices and product pages.",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Dinobilli/watchmark.git"
  },
  "bugs": {
    "url": "https://github.com/Dinobilli/watchmark/issues"
  },
  "homepage": "https://github.com/Dinobilli/watchmark#readme",
  "keywords": [
    "website-monitoring",
    "change-detection",
    "korea",
    "public-notices",
    "ecommerce"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "build": "bun build ./src/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "hono": "^4.10.2",
    "ky": "^1.12.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
