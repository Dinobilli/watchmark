{
  "name": "watchmark",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "build": "bun build ./src/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "hono": "^4.10.2",
    "ky": "^1.12.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
